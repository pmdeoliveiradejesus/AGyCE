 216  CE2..         EP1 =e= Benefit1;
 217  CE3..         EP2 =e= Benefit2;
 218  CE4.. E1 =e=  365*(sum((t), (epsilon(t)-varphis)*P12CDS(t))-sum((t), (epsilon(t)+varphib)*P21CDS(t)));
 219  CE5.. E2 =e=  365*(sum((t), (epsilon(t)-varphis)*P21CDS(t))-sum((t), (epsilon(t)+varphib)*P12CDS(t)));
 220  CE6..         APA  =e=(2*delta)*PmaxCDS+(365)*(sum((t), (varphis+varphib)*(P12CDS(t)+P21CDS(t))));
 221  CE7..         I1_Profit =e= EP1+E1;
 222  CE8..         I2_Profit =e= EP2+E2;
